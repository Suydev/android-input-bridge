<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network: receive input packets -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Wi-Fi Direct -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Auto-start on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Clipboard for text injection -->
    <uses-permission android:name="android.permission.READ_CLIPBOARD" />

    <!-- Battery -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Notifications (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Phase 7: cursor dot overlay.
        Required by CursorOverlayService to draw a floating crosshair on top of
        all other apps. User grants this via Settings.ACTION_MANAGE_OVERLAY_PERMISSION.
        Guarded in the Settings screen and in CursorOverlayService itself.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".ReceiverApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InputBridgeReceiver">

        <!--
            Phase 7: screenOrientation removed (was "portrait").
            The receiver tablet should support both orientations freely.
            android:configChanges handles rotation without restarting the activity.
        -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service keeping the receiver alive -->
        <service
            android:name=".service.ReceiverService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:enabled="true" />

        <!--
            Phase 7: cursor dot overlay service.
            Not a foreground service — just a lightweight WindowManager overlay.
            Only started when the user enables showCursorOverlay AND canDrawOverlays()
            returns true. Uses TYPE_APPLICATION_OVERLAY (API 26+).
        -->
        <service
            android:name=".service.CursorOverlayService"
            android:exported="false"
            android:enabled="true" />

        <!-- Accessibility service for input injection -->
        <service
            android:name="com.inputbridge.accessibility.InputBridgeAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Auto-start on reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
