<?xml version="1.0" encoding="utf-8"?>
<!--
    InputBridge — Receiver app launcher icon foreground.

    Design concept: a tablet (portrait) with a dark screen and a classic mouse-cursor
    arrow on the display, representing "this device receives and injects pointer/key
    events sent wirelessly from the bridge phone".

    Colors: #4FC3F7 (light blue) for the tablet shell — matches ReceiverPrimary used
    throughout the receiver UI. White cursor for contrast on the dark screen.
    Safe zone: 66dp centred on the 108dp canvas (21–87). All content fits within 36–72.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Tablet body (portrait rounded rect) ───────────────────────────── -->
    <path
        android:fillColor="#4FC3F7"
        android:pathData="M44,22 L64,22 Q72,22 72,30 L72,79 Q72,87 64,87 L44,87 Q36,87 36,79 L36,30 Q36,22 44,22 Z"/>

    <!-- ── Screen (dark inset) ────────────────────────────────────────────── -->
    <path
        android:fillColor="#0A1628"
        android:pathData="M40,30 L68,30 L68,76 L40,76 Z"/>

    <!-- ── Home button dot ────────────────────────────────────────────────── -->
    <path
        android:fillColor="#4FC3F7"
        android:pathData="M51.5,82 A2.5,2.5 0 0,0 56.5,82 A2.5,2.5 0 0,0 51.5,82"/>

    <!-- ── Mouse cursor arrow on screen (white) ──────────────────────────── -->
    <!--
        Classic pointer: tip at top-left (46,36), body extends down-right,
        with the characteristic notch for the stem.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,36 L46,61 L51,56 L55.5,66 L59.5,64 L55,54 L61,54 Z"/>

    <!-- ── Cursor accent (blue tint on left edge — depth illusion) ────────── -->
    <path
        android:fillColor="#4FC3F7"
        android:pathData="M46,36 L46,61 L49,58 L46,36 Z"/>

</vector>
