<?xml version="1.0" encoding="utf-8"?>
<!--
    InputBridge — Bridge app launcher icon foreground.

    Design concept: a keyboard key (the bridge phone is the keyboard sender) with a
    right-pointing arrow inside (representing "send / forward input") and a Wi-Fi
    signal below (representing wireless transport to the receiver tablet).

    Colors: teal #00D4AA — matches BridgePrimary used throughout the bridge UI.
    Safe zone: 66dp centred on the 108dp canvas (18–90). All content fits within 25–83.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Keyboard key body (wide rounded rect) ──────────────────────────── -->
    <path
        android:fillColor="#00D4AA"
        android:pathData="M33,28 L75,28 Q83,28 83,36 L83,56 Q83,64 75,64 L33,64 Q25,64 25,56 L25,36 Q25,28 33,28 Z"/>

    <!-- ── Right-pointing arrow punched into the key (dark, cutout effect) ── -->
    <path
        android:fillColor="#101820"
        android:pathData="M34,49 L34,41 L55,41 L55,34 L74,46 L55,58 L55,51 L34,51 Z"/>

    <!-- ── Wi-Fi dot (centre of signal) ──────────────────────────────────── -->
    <path
        android:fillColor="#00D4AA"
        android:pathData="M51.5,80 A2.5,2.5 0 0,0 56.5,80 A2.5,2.5 0 0,0 51.5,80"/>

    <!-- ── Wi-Fi arc 1 (inner) ────────────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#00D4AA"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M47,77 Q54,70 61,77"/>

    <!-- ── Wi-Fi arc 2 (outer) ────────────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#00D4AA"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M42,73 Q54,63 66,73"/>

</vector>
